   // __asm__ volatile("isb\n\t");
    //printf("MAIR_EL1 set to 0x%x\n", mair);


    // 2) 写 TTBR0_EL1
    pgd_t * user_pgd =(pgd_t*)current->mm.pgd;

    unsigned long pgd_phys = (unsigned long)current->mm.pgd;
    
   
printf("sp = 0x%x\n", (unsigned long)__builtin_frame_address(0));
    return 0;
}
 
void copy_kernel_mappings(pgd_t *dest_pgd, pgd_t *kernel_pgd) {
    if (!dest_pgd || !kernel_pgd) {
        printf("Invalid PGD pointers\n");
        return;
    }



    // 只拷贝 PGD[511]：内核映射在最高虚拟地址区
    dest_pgd[511] = kernel_pgd[511];  // 共享内核PUD，避免复制


    printf("Shared kernel mapping: dest PGD[511] = 0x%x,src PGD[511]=%x\n", pgd_val(dest_pgd[511]),pgd_val(kernel_pgd[511]));
}


/*

内核栈页面 (4KB):
内核栈页面 (4KB):
┌─────────────────────┐ <- 0x2000 (tsk->stack + THREAD_SIZE, 栈顶边界)
│                     │
│    struct pt_regs   │ ← 0x1EE0 - 0x2000 这整个区域都是 pt_regs
│                     │   (假设 sizeof(struct pt_regs) = 0x120 = 288字节)
│ ├── regs[0] (x0)    │
│ ├── regs[1] (x1)    │
│ ├── ...             │
│ ├── regs[30] (x30)  │
│ ├── sp              │
│ ├── pc              │
│ └── pstate          │
├─────────────────────┤ <- 0x1EE0 (task_pt_regs 返回的地址)
│                     │
│   可用栈空间        │
│   (向下增长)        │
│        ↓            │
│                     │
└─────────────────────┘ <- 0x1000 (tsk->stack, 栈底)
*/
struct pt_regs * task_pt_regs(struct task_struct *tsk){
	unsigned long p = (unsigned long)tsk->stack + THREAD_SIZE - sizeof(struct pt_regs);
	return (struct pt_regs *)p;
}
unsigned long create_user_executable_pte(unsigned long phys_addr) {
    unsigned long pte_val = 0;
    
    // 基本页表条目
    pte_val |= PTE_VALID;           // bit 0: 有效
    pte_val |= PTE_TYPE_PAGE;       // bits [1:0]: 页面类型
    pte_val |= PTE_USER;            // bit 6: 用户可访问
    // 注意：不设置 PTE_RDONLY，这样页面是可读写的
    pte_val |= PTE_SHARED;          // bits [9:8]: 内部共享
    pte_val |= PTE_AF;              // bit 10: 访问标志
    pte_val |= PTE_NG;              // bit 11: 非全局
   // pte_val |= PTE_PXN;
    pte_val |= PTE_RDONLY;  // 使其只读
    
    // 关键：不设置 UXN 位，允许用户执行
    // 不设置 PXN 位，允许特权执行
    
    // 添加物理地址 (bits [47:12])
    pte_val |= (phys_addr & 0xFFFFFFFFF000UL);
    
    return pte_val;
}
#define PTE_VALID       (1UL << 0)   // bit 0: Valid
#define PTE_TYPE_TABLE  (3UL << 0)   // bits [1:0] = 11 for table
#define PTE_TYPE_PAGE   (3UL << 0)   // bits [1:0] = 11 for page
#define PTE_USER        (1UL << 6)   // bit 6: AP[1] - User accessible
#define PTE_RDONLY      (1UL << 7)   // bit 7: AP[2] - Read only
#define PTE_SHARED      (3UL << 8)   // bits [9:8]: SH[1:0] - Inner shareable
#define PTE_AF          (1UL << 10)  // bit 10: Access flag
#define PTE_NG          (1UL << 11)  // bit 11: nG (not global)
#define PTE_PXN         (1UL << 53)  // bit 53: PXN (Privileged execute never)
#define PTE_UXN         (1UL << 54)  // bit 54: UXN (User execute never)

// 分析当前PTE值 0x7c1
void analyze_pte_permissions(unsigned long pte_val) {
    printf("PTE value: 0x%x analysis:\n", pte_val);
       printf("PTE high value: 0x%x analysis:\n", pte_val>>32);
    printf("  Valid: %s\n", (pte_val & PTE_VALID) ? "Yes" : "No");
    printf("  Type: %s\n", ((pte_val & 3) == 3) ? "Page" : "Other");
    printf("  User accessible (AP[1]): %s\n", (pte_val & PTE_USER) ? "Yes" : "No");
    printf("  Read-only (AP[2]): %s\n", (pte_val & PTE_RDONLY) ? "Yes" : "No");
    printf("  Access flag: %s\n", (pte_val & PTE_AF) ? "Set" : "Not set");
    printf("  Shareable: 0x%x\n", (pte_val >> 8) & 3);
    printf("  Not global: %s\n", (pte_val & PTE_NG) ? "Yes" : "No");
    
    // 检查执行权限 (这些位在高位，需要扩展检查)
    if (pte_val & (1UL << 53)) printf("  PXN: Set (Privileged XN)\n");
    if (pte_val & (1UL << 54)) printf("  UXN: Set (User XN)\n");
}

int move_to_user_mode_fixed(unsigned long start, unsigned long size, unsigned long pc) {
    struct pt_regs *regs = task_pt_regs(current);
    
    // 1. 确保目标地址按页对齐
    
    printf("Mapping user code:  start=0x%x, size=%u\n", start, size);
    
    // 2. 分配并映射用户代码页
    unsigned long phys_page = allocate_user_page(current, start); //USER_FLAGS_DATA// 可执行
    if (!phys_page) {
        printf("ERROR: Failed to allocate user code page\n");
        return -1;
    }
           void *src_va  = (void *)start; 
    printf(" user code: phys_page=0x%x, \n", phys_page);
    // 3. 复制代码到用户页
    void *kernel_va = __va(phys_page);
    _memcpy(kernel_va, src_va, size);
    printf(" user code: _memcpy kernel_va=0x%x,0x%x, \n", kernel_va);
//unsigned long   pte_val=create_user_executable_pte(phys_page);
 //printf("Creating executable PTE: 0x%x\n", pte_val);
//analyze_pte_permissions(pte_val);
    
    
    // 4. 确保指令缓存一致性
    flush_icache_range((unsigned long)kernel_va, (unsigned long)kernel_va + size);
    
    // 5. 分配用户栈
    unsigned long stack_va = USER_STACK_BASE - USER_STACK_SIZE;
    
   unsigned long stack_page = allocate_user_page(current, stack_va); //USER_FLAGS_DATA
   if (!stack_page) {
       printf("ERROR: Failed to allocate user stack page\n");
       return -1;
    }

    
    // 6. 设置寄存器状态
    memzero(regs,  sizeof(*regs));
    regs->pstate = 0x3c0;  // 0x3c0 是正确的
regs->pc = pc;               // 确保是映射的虚拟地址
  regs->sp = stack_va + USER_STACK_SIZE;         // 栈顶

    
    printf("User mode setup:\n");
    printf("  PC = 0x%x\n", regs->pc);
    printf("  SP = 0x%x\n", regs->sp);
    printf("  PSTATE = 0x%x\n", regs->pstate);

     // __asm__ volatile (
      //  "msr ttbr0_el1, %0\n\t"
     //   "tlbi vmalle1is\n\t"
     //   "dsb ish\n\t"
     //   "isb\n\t"
     //   :
      //  : "r"(current->mm->pgd)
      //  : "memory"
    //);

     uint16_t user_asid = 1;  // 为用户进程分配ASID=1
    
    // 设置TTBR0_EL1时包含ASID
    uint64_t ttbr0 = (uint64_t)user_asid << 48 | (uint64_t)current->mm.pgd;
    asm volatile("msr ttbr0_el1, %0" :: "r"(ttbr0));
    
    // 设置页表后，只无效化这个ASID的条目
    asm volatile("tlbi aside1is, %0" :: "r"(user_asid));
    asm volatile("dsb ish");
    asm volatile("isb");


    dump_pagetable_walk(current->mm.pgd, 0x400000);    // 检查用户代码
    dump_pagetable_walk(current->mm.pgd, 0x7fff000);   // 检查用户栈
    

__asm__ volatile(
    "dsb sy\n\t"
    "tlbi vaae1is, %0\n\t"
    "tlbi vaae1is, %1\n\t"
        "tlbi vaae1is, %2\n\t"
    "dsb sy\n\t"
    "isb\n\t"
    :: "r"(0x400000 >> 12), "r"(0x7fff000 >> 12),"r"(0x8000000 >> 12)
    : "memory"
);


  __asm__ volatile(
    "msr    ELR_EL1, %0\n\t"   // 把 regs->pc（0x400050）写到 ELR_EL1
    "msr    SPSR_EL1, %1\n\t"  // 把 regs->pstate（PSR_MODE_EL0t）写到 SPSR_EL1
    "msr    SP_EL0, %2\n\t"    // 把 regs->sp（0x7fff000）写到 SP_EL0
  // "eret\n"                 // 一条指令跳到 EL0 执行用户态
    :
    : "r"(regs->pc), "r"(regs->pstate), "r"(regs->sp)
    : "memory"
);
    
    // 7. 调试：验证页表映射
    //debug_page_table_mapping(regs->pc);
    return 0;
}

//方法1: 完整的缓存刷新实现
void flush_icache_range(unsigned long start, unsigned long end)
{
    unsigned long addr;
    unsigned long cache_line_size;
    
    // 获取缓存行大小 (通常是64字节)
    asm volatile("mrs %0, ctr_el0" : "=r" (cache_line_size));
    cache_line_size = 4 << ((cache_line_size >> 16) & 0xF); // DminLine字段
    
    // 1. 数据缓存清理 (Clean) - 确保数据写入内存
    for (addr = start & ~(cache_line_size - 1); addr < end; addr += cache_line_size) {
        asm volatile("dc cvau, %0" : : "r" (addr) : "memory");
    }
    
    // 2. 数据同步屏障 - 确保所有缓存操作完成
    asm volatile("dsb ish" : : : "memory");
    
    // 3. 指令缓存无效化 (Invalidate)
    for (addr = start & ~(cache_line_size - 1); addr < end; addr += cache_line_size) {
        asm volatile("ic ivau, %0" : : "r" (addr) : "memory");
    }
    
    // 4. 数据同步屏障 - 确保指令缓存操作完成
    asm volatile("dsb ish" : : : "memory");
    
    // 5. 指令同步屏障 - 确保后续指令获取使用新的缓存内容
    asm volatile("isb" : : : "memory");
}

