         for(int i=0;i<64;i++)
         printf("code_rec[%d]=0x%x\n",i,code_rec[i]);

        // 举例：打印 PGD[ <0x400000 索引> ] 的值
    unsigned long *pgd_base = (unsigned long *)__va(current->mm.pgd);
    int pgd_index = (0x400000 >> 39) & 0x1FF;  // AArch64 通常每级用 9 位索引
    printf("Child PGD[%d] = 0x%x\n", pgd_index, pgd_base[pgd_index]);

    // 分配栈页（从栈底向下增长）
    unsigned long stack_va = USER_STACK_BASE  - USER_STACK_SIZE;
    unsigned long stack_page = allocate_user_page(current, stack_va);//0xb43 // User-writable, no execute);USER_FLAGS_DATA
    if (!stack_page) {
      //  free_page(code_page - VA_START);
        return -1;
    }
    printf(" after  allocate stack_page %x,stack_va=%x \n\r",stack_page,stack_va);


 
    regs->pstate = PSR_MODE_EL0t|PSR_DAIF_MASK;  
    regs->pc =pc;    
    printf(" regs->pc  pc=%x\r\n",pc);            
    regs->sp =stack_va + USER_STACK_SIZE ; 


    printf("user jump: current->mm->pgd=%x, pc=0x%x sp=0x%x pstate=0x%x\n",current->mm.pgd,regs->pc, regs->sp, regs->pstate);
	//debug_pgd_recursive(current->mm->pgd);
   
    u64 kernel_pgd = kernel_pgd_addr();
    //set_pgd(current->mm->pgd,regs);
 //dump_pagetable_walk(get_pgd(), 0xFFFFF83f000000);    // 检查用户代码
    //__asm__ volatile (
   //     "msr ttbr0_el1, %0\n\t"
     //   "tlbi vmalle1is\n\t"
     //   "dsb ish\n\t"
    //    "isb\n\t"
     //   :
     //   : "r"(current->mm->pgd)
    //    : "memory"
    //);
       // 1) 载入新的用户页表根
       __asm__ volatile (
          // 0) Configure TCR_EL1 for Inner‑Shareable (SH0 = 01)
    "mrs    x2, tcr_el1            \n\t"
    "orr    x2, x2, #(1 << 8)       \n\t"  // set SH0 field to 01b
    "msr    tcr_el1, x2            \n\t"
    "isb                            \n\t"

    "msr    ttbr0_el1, %0\n\t"
    "msr    ttbr1_el1, %1\n\t"
    // 2) 确保对寄存器写入和页表修改可见
    "dsb    sy\n\t"
    "isb\n\t"
    // 3) 清空旧的用户 TLB（虚拟地址到物理地址缓存）

  //  "tlbi   vmalle1is\n\t"
  //  "dsb    sy\n\t"
  // "isb\n\t"

      // 3) Invalidate only the user code and stack pages by VA
    "tlbi   vaae1is, %2           \n\t"  // code VA 0x400000
    "tlbi   vaae1is, %3           \n\t"  // stack VA 0x7fff000
    "dsb    sy                    \n\t"
    "isb                          \n\t"
    // 4) 如果刚刚 memcpy 了新代码页，再清 I‑cache
    "ic     iallu\n\t"
   // "ic ivau, %4\n\t"
    "dsb    sy\n\t"
    "isb\n\t"
    :
    : "r"(current->mm.pgd),"r"(kernel_pgd),"r"(0x400000 >> 12), "r"(0x7fff000 >> 12),"r"(0x400000)
    : "x2", "memory"
);



